# ---- Admin dashboard login ----
# Password you'll type to log into your own dashboard
ADMIN_PASSWORD=
# Random 32+ char string used to sign your session cookie
SESSION_SECRET=

# ---- Google OAuth (Desktop app client) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Minted by: node scripts/get-google-token.mjs
GOOGLE_REFRESH_TOKEN=
# Account to read email/calendar from and send thank-yous from
GOOGLE_USER_EMAIL=
# Name that thank-you emails are signed with
SENDER_NAME=

# ---- Anthropic (classification + drafting) ----
ANTHROPIC_API_KEY=

# ---- Postgres (Neon / Vercel Postgres) ----
DATABASE_URL=

# ---- Cron protection ----
# Random string; Vercel Cron sends this so only Vercel can trigger the daily job
CRON_SECRET=

# ---- Public base URL (card links). Set to your Vercel URL after deploy ----
NEXT_PUBLIC_BASE_URL=http://localhost:3000
